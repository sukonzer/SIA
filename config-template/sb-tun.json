        "🎯 直连",
        "🇺🇲 美国节点"
      ]
    },
    {
      "tag": "🇺🇲 美国节点",
      "type": "selector",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "🇺🇸|US|us|美国|美|United States"
          ]
        }
      ]
    },
    {
      "tag": "🔯 故障转移",
      "type": "urltest",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "include",
          "keywords": [
            "🇭🇰|HK|hk|香港|港|HongKong",
            "🇹🇼|TW|tw|台湾|臺灣|台|Taiwan"
          ]
        }
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 50
    },
    {
      "tag": "🚄 高速网络",
      "type": "urltest",
      "outbounds": [
        "{all}"
      ],
      "filter": [
        {
          "action": "exclude",
          "keywords": [
            "网站|地址|剩余|过期|到期|时间|有效"
          ]
        }
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "10m",
      "tolerance": 50
    },
    {
      "tag": "🌐 代理",
      "type": "selector",
      "outbounds": [
        "{all}"
      ]
    },
    {
      "tag": "🎯 直连",
      "type": "direct"
    }
  ],
