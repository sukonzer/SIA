{
    "log": {
        "disabled": false,
        "level": "warn",
        "timestamp": true
    },
    "experimental": {
        "clash_api": {
            "default_mode": "Rule"
        },
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": true
        }
    },
    "dns": {
        "fakeip": {
            "enabled": true,
            "inet4_range": "198.18.0.0/15",
            "inet6_range": "fc00::/18"
        },
        "servers": [
            {
                "tag": "direct_dns",
                "address": "https://223.5.5.5/dns-query",
                "detour": "🎯 Direct",
                "strategy": "prefer_ipv4"
            },
            {
                "tag": "proxy_dns",
                "address": "tls://8.8.8.8",
                "detour": "🎯 Node",
                "strategy": "prefer_ipv4"
            },
            {
                "tag": "fakeip",
                "address": "fakeip"
            }
        ],
        "rules": [
            {
                "outbound": "any",
                "server": "direct_dns",
                "disable_cache": true
            },
            {
                "clash_mode": "Direct",
                "server": "direct_dns"
            },
            {
                "clash_mode": "Global",
                "server": "proxy_dns"
            },
            {
                "query_type": [
                    "A",
                    "AAAA"
                ],
                "server": "fakeip",
                "rewrite_ttl": 1
            },
            {
                "domain_suffix": [
                    "services.googleapis.cn",
                    "googleapis.cn",
                    "xn--ngstr-lra8j.com"
                ],
                "server": "proxy_dns"
            },
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "rule_set": "geosite-geolocation-!cn",
                        "invert": true
                    },
                    {
                        "rule_set": "geoip-cn"
                    }
                ],
                "server": "proxy_dns",
                "client_subnet": "221.131.143.0/24"
            },
            {
                "rule_set": "geosite-cn",
                "server": "direct_dns"
            }
        ],
        "independent_cache": true
    },
    "inbounds": [
        {
            "tag": "tun-in",
            "type": "tun",
            "address": [
                "172.19.0.1/30",
                "fdfe:dcba:9876::1/126"
            ],
            "mtu": 9000,
            "auto_route": true,
            "strict_route": true
        }
    ],
    "route": {
        "auto_detect_interface": true,
        "final": "🎯 Node",
        "rules": [
            {
                "action": "sniff",
                "timeout": "500ms"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "port": 53
                    },
                    {
                        "protocol": "dns"
                    }
                ],
                "action": "hijack-dns"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "port": 853
                    },
                    {
                        "network": "udp",
                        "port": 443
                    },
                    {
                        "protocol": "stun"
                    }
                ],
                "action": "reject"
            },
            {
                "ip_is_private": true,
                "outbound": "🎯 Direct"
            },
            {
                "clash_mode": "Direct",
                "outbound": "🎯 Direct"
            },
            {
                "clash_mode": "Global",
                "outbound": "🌐 Proxy"
            },
            {
                "rule_set": [
                    "geoip-google",
                    "geosite-google",
                    "geosite-github"
                ],
                "outbound": "🔍 Google"
            },
            {
                "rule_set": "geosite-ai",
                "outbound": "🤖 AI"
            },
            {
                "rule_set": [
                    "geosite-youtube",
                    "geosite-tiktok"
                ],
                "outbound": "📹 YouTube"
            },
            {
                "rule_set": [
                    "geoip-telegram",
                    "geosite-telegram"
                ],
                "outbound": "📲 Telegram"
            },
            {
                "rule_set": [
                    "geoip-netflix",
                    "geosite-netflix"
                ],
                "outbound": "🎥 Netflix"
            },
            {
                "domain_suffix": [
                    "tktn.at",
                    "tktn.be",
                    "vm.talkatone.com",
                    "tenor.com"
                ],
                "outbound": "🎯 Node"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
