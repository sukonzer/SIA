                    ]
                }
            ]
        },
        {
            "tag": "🚄 Auto",
            "type": "urltest",
            "outbounds": [
                "{all}"
            ],
            "filter": [
                {
                    "action": "exclude",
                    "keywords": [
                        "网站|官网|地址|剩余|过期|到期|时间|有效|tg|群|订阅|刷新",
