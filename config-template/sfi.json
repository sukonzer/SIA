    "outbounds": [
        {
            "tag": "🎯 Node",
            "type": "selector",
            "outbounds": [
                "🌐 Proxy",
                "🔯 Nearby",
                "🇺🇲 USA",
                "🚄 Auto",
                "🎯 Direct"
            ]
        },
        {
            "tag": "🔍 Google",
            "type": "selector",
            "outbounds": [
                "🇺🇲 USA",
                "🔯 Nearby",
                "🌐 Proxy"
            ]
        },
        {
            "tag": "📹 YouTube",
            "type": "selector",
            "outbounds": [
                "🌐 Proxy",
                "🚄 Auto",
                "🔯 Nearby",
                "🇺🇲 USA"
            ]
        },
        {
            "tag": "🤖 AI",
