                "outbound": "🎯 Direct"
            },
            {
                "domain_suffix": [
                    "ping0.cc",
                    "ippure.com",
                    "ip.sb",
                    "iplark.com",
                    "speedtest.net"
                ],
                "outbound": "🔀 Other"
