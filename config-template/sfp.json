            {
                "tag": "proxy_dns",
                "type": "h3",
                "server": "dns.google",
                "domain_resolver": "hosts_dns",
                "detour": "🎯 Node"
            },
            {
                "tag": "local_dns",
                "type": "local"
            },
            {
                "tag": "fakeip_dns",
                "type": "fakeip",
                "inet4_range": "198.18.0.0/15",
                "inet6_range": "fc00::/64"
            },
            {
                "tag": "hosts_dns",
                "type": "hosts",
                "predefined": {
                    "dns.alidns.com": [
                        "223.5.5.5",
                        "223.6.6.6",
                        "2400:3200::1",
                        "2400:3200:baba::1"
                    ],
                    "doh.pub": [
                        "1.12.12.21",
                        "120.53.53.53",
                        "2402:4e00::",
                        "2402:4e00:1::"
                    ],
                    "dns.google": [
                        "8.8.8.8",
                        "8.8.4.4",
                        "2001:4860:4860::8888",
                        "2001:4860:4860::8844"
                    ],
                    "cloudflare-dns.com": [
                        "104.16.248.249",
                        "104.16.249.249",
                        "2606:4700:4700::1111",
                        "2606:4700:4700::1001"
                    ]
                }
            }
        ],
        "rules": [
            {
                "clash_mode": "Direct",
                "server": "direct_dns"
            },
            {
                "clash_mode": "Global",
                "server": "proxy_dns"
            },
            {
                "query_type": "PTR",
                "server": "local_dns"
            },
            {
                "query_type": [
                    "SVCB",
                    "HTTPS"
                ],
                "action": "reject"
            },
            {
                "rule_set": "geosite-cn",
                "server": "direct_dns"
            },
            {
                "query_type": [
                    "A",
                    "AAAA"
                ],
                "server": "fakeip_dns",
                "rewrite_ttl": 1
            }
        ],
        "final": "proxy_dns",
        "independent_cache": true,
        "strategy": "prefer_ipv4",
        "client_subnet": "221.131.143.0/24"
    },
    "inbounds": [
        {
            "tag": "tun-in",
            "type": "tun",
            "address": [
                "172.19.0.1/30",
                "fdfe:dcba:9876::1/126"
            ],
            "mtu": 9000,
            "auto_route": true,
            "strict_route": true
        },
        {
            "tag": "mixed-in",
            "type": "mixed",
            "listen": "127.0.0.1",
            "listen_port": 7890,
            "set_system_proxy": false
        }
    ],
    "route": {
        "auto_detect_interface": true,
        "final": "🎯 Node",
        "default_domain_resolver": {
            "server": "proxy_server_dns",
            "strategy": "prefer_ipv4"
        },
        "rules": [
            {
                "type": "logical",
                "mode": "and",
                "rules": [
                    {
                        "ip_version": 6
                    },
                    {
                        "default_interface_address": [
                            "2000::/3"
                        ],
                        "invert": true
                    }
                ],
                "action": "reject"
            },
            {
                "action": "sniff",
                "timeout": "500ms"
            },
            {
                "type": "logical",
                "mode": "or",
                "rules": [
                    {
                        "port": 53
                    },
                    {
                        "protocol": "dns"
                    }
                ],
                "action": "hijack-dns"
            },
            {
                "ip_is_private": true,
                "outbound": "🎯 Direct"
            },
            {
                "clash_mode": "Direct",
                "outbound": "🎯 Direct"
            },
            {
                "clash_mode": "Global",
