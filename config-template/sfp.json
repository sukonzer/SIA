            "secret": "",
            "external_ui_download_url": "https://gh-proxy.com/github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip",
            "default_mode": "Rule"
        },
        "cache_file": {
            "enabled": true,
            "path": "cache.db",
            "store_fakeip": true,
            "cache_id": "all"
        }
    },
    "ntp": {
        "enabled": true,
        "server": "time.apple.com",
